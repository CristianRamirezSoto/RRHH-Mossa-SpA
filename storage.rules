rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && firestore.get(
          /databases/(default)/documents/users/$(request.auth.uid)
        ).data.role == 'admin';
    }

    function isOwner() {
      return signedIn()
        && resource.metadata.ownerEmail == request.auth.token.email;
    }

    match /documents/{documentId}/{fileName} {
      allow read: if isAdmin() || isOwner();
      allow create, update: if isAdmin()
        && request.resource.size <= 15 * 1024 * 1024
        && request.resource.metadata.ownerEmail is string;
      allow delete: if isAdmin();
    }

    match /employees/{employeeId}/documents/{documentId}/{fileName} {
      allow read: if isAdmin() || isOwner();
      allow create, update: if isAdmin()
        && request.resource.size <= 15 * 1024 * 1024
        && request.resource.metadata.ownerEmail is string
        && request.resource.metadata.employeeId == employeeId;
      allow delete: if isAdmin();
    }
  }
}
