# Copia este archivo como .env.local y completa con los datos de tu proyecto Firebase
# (Configuración del proyecto > Tus apps > SDK setup and configuration)
# Para desarrollo 100% local con emuladores, puedes dejar estos valores de ejemplo tal cual.

VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-project
VITE_FIREBASE_STORAGE_BUCKET=demo-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Pon "true" para conectar a los emuladores locales en vez de Firebase real
VITE_USE_EMULATORS=true

# Clave pública Web Push de Firebase Cloud Messaging.
# Se obtiene en Firebase > Configuración del proyecto > Cloud Messaging.
VITE_FIREBASE_VAPID_KEY=
VITE_ADMIN_EMAIL=admin@tu-dominio.cl

# Supabase Storage para expedientes digitales sin Firebase Blaze.
# En Supabase: Project Settings > API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_DOCUMENT_BUCKET=employee-documents

# Numero de WhatsApp para pruebas de avisos RRHH.
# Formato recomendado Chile: 569XXXXXXXX
VITE_HR_WHATSAPP_NUMBER=
